{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "run-app",
            "command": "python",
            "args": [
                "-m",
                "uvicorn",
                "src.app:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8000",
                "--reload"
            ],
            "group": "build"
        }
    ]
}